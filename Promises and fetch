// Let's create a promise (The restaurant buzzer)
const orderFood = new Promise((resolve, reject) => {
  let foodReady = true; // Change this to false to see what happens when it fails!

  if (foodReady) {
    resolve("Here is your delicious burger! 🍔"); // Success!
  } else {
    reject("Sorry, we ran out of ingredients. ❌"); // Failure!
  }
});

// How we USE the promise
orderFood
  .then((food) => {
    // This runs ONLY if resolve() was called
    console.log(food); 
  })
  .catch((error) => {
    // This runs ONLY if reject() was called
    console.log(error); 
  });



// 1. Producer: creating the promise
function loadData() {
  return new Promise((resolve, reject) => {
    let success = true;

    setTimeout(() => {
      if (success) {
        resolve("Data loaded"); // success
      } else {
        reject("Failed to load data"); // error
      }
    }, 1000);
  });
}

// 2. Another step in the chain
function saveData(data) {
  return new Promise((resolve, reject) => {
    setTimeout(() => {
      resolve(data + " -> Data saved");
    }, 1000);
  });
}

// 3. Another step
function sendEmail(data) {
  return new Promise((resolve, reject) => {
    setTimeout(() => {
      resolve(data + " -> Email sent");
    }, 1000);
  });
}

// 4. Using the promise (consumer)
loadData()
  .then(saveData)
  .then(sendEmail)
  .then((result) => {
    console.log(result);
  })
  .catch((err) => {
    console.log("Error:", err);
  })
  .finally(() => {
    console.log("Process finished");
  });
